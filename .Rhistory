df <- read.csv('/Users/kaisarthik/Library/CloudStorage/OneDrive-purdue.edu/25-26/STAT 512/STAT-512-Final-Project/heart_failure_clinical_records_dataset 2.csv')
age_model <- glm(
DEATH_EVENT ~ age + anaemia + creatinine_phosphokinase + diabetes +
ejection_fraction + high_blood_pressure + platelets +
serum_creatinine + serum_sodium + sex + smoking,
data = df,
family = binomial(link = "logit")
)
summary(age_model)
or_table <- cbind(
OR    = exp(coef(age_model)),
exp(confint.default(age_model))
)
colnames(or_table) <- c("OR", "2.5 %", "97.5 %")
round(or_table, 4)
null_model <- glm(DEATH_EVENT ~ 1, data = df, family = binomial(link = "logit"))
anova(null_model, age_model, test = "Chisq")
# McFadden pseudo-R^2
mcfadden <- 1 - (age_model$deviance / age_model$null.deviance)
cat(sprintf("McFadden pseudo-R^2: %.4f\n", mcfadden))
reduced_model <- glm(
DEATH_EVENT ~ age + creatinine_phosphokinase + ejection_fraction + serum_creatinine,
data = df,
family = binomial(link = "logit")
)
summary(reduced_model)
glt <- anova(reduced_model, age_model, test = "Chisq")
print(glt)
cat("\nChi-square critical value (df = 7, alpha = 0.05):",
round(qchisq(0.95, 7), 4), "\n")
cat("Chi-square test statistic:", round(glt$Deviance[2], 4), "\n")
cat("p-value:", signif(glt$`Pr(>Chi)`[2], 4), "\n")
cat("Full model     — AIC:", round(AIC(age_model), 2),
"  BIC:", round(BIC(age_model), 2), "\n")
cat("Reduced model  — AIC:", round(AIC(reduced_model), 2),
"  BIC:", round(BIC(reduced_model), 2), "\n")
# McFadden pseudo-R^2 for the reduced model
mcfadden_red <- 1 - (reduced_model$deviance / reduced_model$null.deviance)
cat(sprintf("Reduced model McFadden pseudo-R^2: %.4f\n", mcfadden_red))
or_red <- cbind(
OR = exp(coef(reduced_model)),
exp(confint.default(reduced_model))
)
colnames(or_red) <- c("OR", "2.5 %", "97.5 %")
round(or_red, 4)
minimal_model <- glm(
DEATH_EVENT ~ age + ejection_fraction + serum_creatinine,
data = df,
family = binomial(link = "logit")
)
summary(minimal_model)
glt_cpk <- anova(minimal_model, reduced_model, test = "Chisq")
print(glt_cpk)
cat("\nChi-square critical (df = 1, alpha = 0.05):",
round(qchisq(0.95, 1), 4), "\n")
cat("Chi-square test statistic:", round(glt_cpk$Deviance[2], 4), "\n")
cat("p-value:", signif(glt_cpk$`Pr(>Chi)`[2], 4), "\n")
glt_full <- anova(minimal_model, age_model, test = "Chisq")
print(glt_full)
cat("\nChi-square critical (df = 8, alpha = 0.05):",
round(qchisq(0.95, 8), 4), "\n")
cat("Chi-square test statistic:", round(glt_full$Deviance[2], 4), "\n")
cat("p-value:", signif(glt_full$`Pr(>Chi)`[2], 4), "\n")
comparison <- data.frame(
AIC      = c(AIC(age_model), AIC(reduced_model), AIC(minimal_model)),
BIC      = c(BIC(age_model), BIC(reduced_model), BIC(minimal_model)),
Deviance = c(age_model$deviance, reduced_model$deviance, minimal_model$deviance),
df_resid = c(age_model$df.residual, reduced_model$df.residual, minimal_model$df.residual),
row.names = c("Full (11 predictors)", "Reduced (4 predictors)", "Minimal (3 predictors)")
)
print(round(comparison, 2))
# McFadden pseudo-R^2 for all three
null_dev <- age_model$null.deviance
cat("\nMcFadden pseudo-R^2:\n")
cat(sprintf("  Full:     %.4f\n", 1 - age_model$deviance     / null_dev))
cat(sprintf("  Reduced:  %.4f\n", 1 - reduced_model$deviance / null_dev))
cat(sprintf("  Minimal:  %.4f\n", 1 - minimal_model$deviance / null_dev))
or_min <- cbind(
OR = exp(coef(minimal_model)),
exp(confint.default(minimal_model))
)
colnames(or_min) <- c("OR", "2.5 %", "97.5 %")
round(or_min, 4)
knitr::opts_chunk$set(echo = TRUE, fig.width = 7, fig.height = 5)
options(scipen = 999)
df <- read.csv("heart_failure_clinical_records_dataset 2.csv")
df$high_blood_pressure <- factor(
df$high_blood_pressure,
levels = c(0, 1),
labels = c("No", "Yes")
)
df$log_cpk <- log(df$creatinine_phosphokinase)
calc_vif <- function(model) {
X <- model.matrix(model)[, -1, drop = FALSE]
out <- numeric(ncol(X))
names(out) <- colnames(X)
for (j in seq_len(ncol(X))) {
fit_j <- lm(X[, j] ~ X[, -j, drop = FALSE])
out[j] <- 1 / (1 - summary(fit_j)$r.squared)
}
out
}
kfold_rmse <- function(formula, data, k = 10, seed = 512) {
set.seed(seed)
folds <- sample(rep(1:k, length.out = nrow(data)))
rmse <- numeric(k)
for (i in seq_len(k)) {
train <- data[folds != i, , drop = FALSE]
test <- data[folds == i, , drop = FALSE]
fit <- lm(formula, data = train)
pred <- predict(fit, newdata = test)
rmse[i] <- sqrt(mean((test$ejection_fraction - pred)^2))
}
c(mean = mean(rmse), sd = sd(rmse))
}
full_model <- lm(
ejection_fraction ~ high_blood_pressure + serum_sodium +
serum_creatinine + creatinine_phosphokinase + age,
data = df
)
log_cpk_model <- lm(
ejection_fraction ~ high_blood_pressure + serum_sodium +
serum_creatinine + log_cpk + age,
data = df
)
reduced_model <- lm(
ejection_fraction ~ serum_sodium + serum_creatinine + age,
data = df
)
sodium_model <- lm(
ejection_fraction ~ serum_sodium,
data = df
)
sodium_age_model <- lm(
ejection_fraction ~ serum_sodium + age,
data = df
)
full_coef <- cbind(
round(coef(summary(full_model)), 4),
round(confint(full_model), 4)
)
vif_table <- data.frame(
term = names(calc_vif(full_model)),
VIF = round(calc_vif(full_model), 3),
row.names = NULL
)
model_metrics <- data.frame(
Model = c(
"Full MLR (raw CPK)",
"Full MLR (log CPK)",
"Reduced: sodium + creatinine + age",
"Sodium only",
"Sodium + age"
),
Adjusted_R2 = c(
summary(full_model)$adj.r.squared,
summary(log_cpk_model)$adj.r.squared,
summary(reduced_model)$adj.r.squared,
summary(sodium_model)$adj.r.squared,
summary(sodium_age_model)$adj.r.squared
),
AIC = c(
AIC(full_model),
AIC(log_cpk_model),
AIC(reduced_model),
AIC(sodium_model),
AIC(sodium_age_model)
),
BIC = c(
BIC(full_model),
BIC(log_cpk_model),
BIC(reduced_model),
BIC(sodium_model),
BIC(sodium_age_model)
),
CV_RMSE = c(
kfold_rmse(formula(full_model), df)["mean"],
kfold_rmse(formula(log_cpk_model), df)["mean"],
kfold_rmse(formula(reduced_model), df)["mean"],
kfold_rmse(formula(sodium_model), df)["mean"],
kfold_rmse(formula(sodium_age_model), df)["mean"]
)
)
sensitivity_models <- list(
"All data" = sodium_model,
"Exclude row 20" = lm(ejection_fraction ~ serum_sodium, data = df[-20, ]),
"Exclude row 226" = lm(ejection_fraction ~ serum_sodium, data = df[-226, ]),
"Exclude rows 20 and 226" = lm(ejection_fraction ~ serum_sodium, data = df[-c(20, 226), ])
)
sensitivity_table <- data.frame(
Sample = names(sensitivity_models),
Beta_serum_sodium = sapply(sensitivity_models, function(m) coef(m)[["serum_sodium"]]),
P_value = sapply(sensitivity_models, function(m) coef(summary(m))["serum_sodium", "Pr(>|t|)"])
)
anova_sodium_vs_reduced <- anova(sodium_model, reduced_model)
anova_reduced_vs_full <- anova(reduced_model, full_model)
anova_sodium_vs_age <- anova(sodium_model, sodium_age_model)
cv_sodium <- kfold_rmse(formula(sodium_model), df)
